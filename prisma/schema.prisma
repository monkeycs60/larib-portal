// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

model User {
  id              String        @id
  email           String        @unique
  emailVerified   Boolean       @default(false)
  name            String?
  // Admin/user management fields
  firstName       String?
  lastName        String?
  phoneNumber     String?
  role            Role          @default(USER)
  country         String?
  birthDate       DateTime?
  language        Language      @default(EN)
  position        String?
  arrivalDate     DateTime?
  departureDate   DateTime?
  profilePhoto    String?
  profilePhotoKey String?
  congesTotalDays Int           @default(0)
  publicationsEmailOptOut Boolean @default(false)
  applications    Application[]
  adminApplications Application[] @default([])
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  image           String?

  sessions Session[]
  accounts Account[]
  leaveRequests      LeaveRequest[]
  leaveApprovals     LeaveRequest[] @relation("LeaveRequestApprover")
  leavePeriods       LeavePeriod[]

  //related to bestof larib
  ClinicalCase     ClinicalCase[]
  UserCaseSettings UserCaseSettings[]
  CaseAttempt      CaseAttempt[]
  UserTag          UserTag[]

  //related to publications
  authoredBy      Author[]
  studiesLed      Study[]   @relation("StudyLead")
  studiesCreated  Study[]   @relation("StudyCreatedBy")
  articlesCreated Article[] @relation("ArticleCreatedBy")

  @@map("User")
}

enum Role {
  ADMIN
  USER
}

enum Language {
  EN
  FR
}

enum Application {
  BESTOF_LARIB
  CONGES
  CARDIOLARIB
}

// ---- Publications domain ----

enum ArticleStatus {
  IN_PREPARATION
  UNDER_REVIEW
  TO_RESUBMIT
  ACCEPTED
  PUBLISHED
  ABANDONED
}

enum ArticleType {
  ORIGINAL
  REVIEW
  CASE_REPORT
  EDITORIAL
  LETTER
  META_ANALYSIS
  OTHER
}

enum SubmissionStatus {
  UNDER_REVIEW
  MINOR_REVISIONS
  MAJOR_REVISIONS
  ACCEPTED
  REJECTED
}

// ---- Bestof Larib domain ----

enum DifficultyLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum CaseStatus {
  DRAFT
  PUBLISHED
}

model ExamType {
  id        String   @id
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cases ClinicalCase[]

  @@map("ExamType")
}

model DiseaseTag {
  id        String   @id
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cases ClinicalCase[]

  @@map("DiseaseTag")
}

model ClinicalCase {
  id         String          @id
  name       String
  difficulty DifficultyLevel
  status     CaseStatus      @default(DRAFT)
  tags       String[]        @default([])
  caseNumber Int             @unique @default(autoincrement())

  // Content: either pdf or text or both (validated at app level)
  pdfUrl      String?
  pdfKey      String?
  textContent String?

  // Relations
  examTypeId   String?
  examType     ExamType?   @relation(fields: [examTypeId], references: [id])
  diseaseTagId String?
  diseaseTag   DiseaseTag? @relation(fields: [diseaseTagId], references: [id])

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id], onDelete: Restrict)

  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  UserCaseSettings UserCaseSettings[]
  CaseAttempt      CaseAttempt[]
  adminTags        AdminTagOnCase[]
  userTags         UserTagOnCase[]

  @@map("ClinicalCase")
}

// User-specific preferences for a given case (not tied to attempts)
model UserCaseSettings {
  id                 String           @id
  userId             String
  caseId             String
  tags               String[]         @default([])
  personalDifficulty DifficultyLevel?
  comments           String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  c    ClinicalCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@unique([userId, caseId])
  @@map("UserCaseSettings")
}

// A user attempt for a given case, can be multiple
model CaseAttempt {
  id          String    @id
  userId      String
  caseId      String
  lvef        String?
  kinetic     String?
  lgePresent  Boolean?
  lgeDetails  String?
  finalDx     String?
  report      String?
  validatedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  c    ClinicalCase @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([userId, caseId])
  @@map("CaseAttempt")
}

model Position {
  id        String   @id
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("Position")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("Session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("Account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("Verification")
}

// ---- Conges domain ----

enum LeaveRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

model LeaveRequest {
  id         String             @id @default(cuid())
  userId     String
  approverId String?
  startDate  DateTime
  endDate    DateTime
  reason     String?
  status     LeaveRequestStatus @default(PENDING)
  decisionAt DateTime?
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  user     User @relation(fields: [userId], references: [id], onDelete: Cascade)
  approver User? @relation("LeaveRequestApprover", fields: [approverId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([startDate])
  @@index([endDate])
  @@map("LeaveRequest")
}

model LeavePeriod {
  id            String   @id @default(cuid())
  userId        String
  startDate     DateTime
  endDate       DateTime
  allocatedDays Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, startDate])
  @@index([userId, endDate])
  @@map("LeavePeriod")
}

// ---- Tagging System for Bestof Larib ----

model AdminTag {
  id          String   @id
  name        String   @unique
  color       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  cases AdminTagOnCase[]

  @@map("AdminTag")
}

model AdminTagOnCase {
  caseId String
  tagId  String

  c         ClinicalCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  tag       AdminTag     @relation(fields: [tagId], references: [id], onDelete: Cascade)
  createdAt DateTime     @default(now())

  @@id([caseId, tagId])
  @@map("AdminTagOnCase")
}

model UserTag {
  id          String   @id
  userId      String
  name        String
  color       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user  User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  cases UserTagOnCase[]

  @@unique([userId, name])
  @@map("UserTag")
}

model UserTagOnCase {
  caseId    String
  userTagId String

  c         ClinicalCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  tag       UserTag      @relation(fields: [userTagId], references: [id], onDelete: Cascade)
  createdAt DateTime     @default(now())

  @@id([caseId, userTagId])
  @@map("UserTagOnCase")
}

// ---- Publications domain models ----

model Study {
  id          String    @id @default(cuid())
  title       String
  description String?
  leadUserId  String?
  leadUser    User?     @relation("StudyLead", fields: [leadUserId], references: [id], onDelete: SetNull)
  startDate   DateTime?
  isClosed    Boolean   @default(false)
  createdById String
  createdBy   User      @relation("StudyCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  articles Article[]

  @@map("Study")
}

model Journal {
  id           String   @id @default(cuid())
  name         String   @unique
  issn         String?
  publisher    String?
  impactFactor Float?
  category     String?
  url          String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  submissions       Submission[]
  targets           JournalTarget[]
  publishedArticles Article[]       @relation("PublishedJournal")

  @@map("Journal")
}

model Affiliation {
  id          String   @id @default(cuid())
  name        String   @unique
  institution String?
  department  String?
  city        String?
  country     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  authorshipAffiliations AuthorshipAffiliation[]
  defaultOfAuthors       Author[]                @relation("AuthorDefaultAffiliation")

  @@map("Affiliation")
}

model Author {
  id                   String       @id @default(cuid())
  firstName            String
  lastName             String
  degrees              String?
  email                String?
  orcid                String?
  defaultAffiliationId String?
  defaultAffiliation   Affiliation? @relation("AuthorDefaultAffiliation", fields: [defaultAffiliationId], references: [id], onDelete: SetNull)
  userId               String?
  user                 User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  authorships Authorship[]

  @@unique([firstName, lastName])
  @@map("Author")
}

model Article {
  id                 String        @id @default(cuid())
  title              String
  type               ArticleType   @default(ORIGINAL)
  studyId            String?
  study              Study?        @relation(fields: [studyId], references: [id], onDelete: SetNull)
  status             ArticleStatus @default(IN_PREPARATION)
  abstract           String?
  pubmedId           String?
  doi                String?
  publishedJournalId String?
  publishedJournal   Journal?      @relation("PublishedJournal", fields: [publishedJournalId], references: [id], onDelete: SetNull)
  publishedAt        DateTime?
  pdfUrl             String?
  pdfKey             String?
  createdById        String
  createdBy          User          @relation("ArticleCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  authorships    Authorship[]
  submissions    Submission[]
  journalTargets JournalTarget[]

  @@map("Article")
}

model Authorship {
  id              String   @id @default(cuid())
  articleId       String
  article         Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  authorId        String
  author          Author   @relation(fields: [authorId], references: [id], onDelete: Restrict)
  order           Int
  isCorresponding Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  affiliations AuthorshipAffiliation[]

  @@unique([articleId, authorId])
  @@unique([articleId, order])
  @@map("Authorship")
}

model AuthorshipAffiliation {
  authorshipId  String
  authorship    Authorship  @relation(fields: [authorshipId], references: [id], onDelete: Cascade)
  affiliationId String
  affiliation   Affiliation @relation(fields: [affiliationId], references: [id], onDelete: Restrict)
  order         Int

  @@id([authorshipId, affiliationId])
  @@map("AuthorshipAffiliation")
}

model Submission {
  id                String           @id @default(cuid())
  articleId         String
  article           Article          @relation(fields: [articleId], references: [id], onDelete: Cascade)
  journalId         String
  journal           Journal          @relation(fields: [journalId], references: [id], onDelete: Restrict)
  submittedAt       DateTime
  status            SubmissionStatus @default(UNDER_REVIEW)
  decidedAt         DateTime?
  invitedToResubmit Boolean          @default(false)
  notes             String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@map("Submission")
}

model JournalTarget {
  id        String   @id @default(cuid())
  articleId String
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  journalId String
  journal   Journal  @relation(fields: [journalId], references: [id], onDelete: Restrict)
  rank      Int
  createdAt DateTime @default(now())

  @@unique([articleId, journalId])
  @@map("JournalTarget")
}
