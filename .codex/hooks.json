{
  "description": "Keep Codex working after a failed push validation.",
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/.agent-hooks/ensure-push-green.mjs\"",
            "timeout": 30,
            "statusMessage": "Checking the latest push validation"
          }
        ]
      }
    ]
  }
}
